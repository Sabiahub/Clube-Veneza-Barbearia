cations: Location[] = [\n  {\n    id: \'loc-matriz\',\n    name: \'Unidade Centro\',\n    address: \'Rua das Flores, 1234 - Bairro Centro, S\303\243o Paulo - SP\',\n    imageUrl: \'https://images.unsplash.com/photo-1585747860715-2ba37e788b70?q=80&w=800&auto=format&fit=crop\',\n    planIds: [\'plan-basic\', \'plan-premium\', \'plan-beard\']\n  },\n  {\n    id: \'loc-sul\',\n    name: \'Unidade Zona Sul\',\n    address: \'Av. das Na\303\247\303\265es, 500 - Boa Viagem, S\303\243o Paulo - SP\',\n    imageUrl: \'https://images.unsplash.com/photo-1633681926022-84c23e8cb2d6?q=80&w=800&auto=format&fit=crop\',\n    planIds: [\'plan-basic\', \'plan-premium\'] // Exemplo: unidade que n\303\243o possui o plano Beard isolado\n  }\n];\n"
